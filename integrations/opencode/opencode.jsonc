{
  // OpenCode Client Plugin 示例配置
  //
  // 将此文件放置在 opencode.jsonc 配置目录下，或在已有配置中合并
  // `plugin` 顶层键。Plugin 路径相对于声明此配置的 opencode.jsonc
  // 所在目录解析。
  //
  // URL 与 Token 使用 {env:...} / {file:...} 插值，不在配置中
  // 硬编码敏感信息。
  //
  // 插件加载后会自动读取配置，缺省 events 时启用所有四类事件。
  //
  // 参考文档：docs/opencode-integration.md

  "plugin": [
    [
      "./integrations/opencode/webhook-notifier.ts",
      {
        // 必填：Webhook 服务端地址（支持环境变量插值）
        "url": "{env:OPENCODE_WEBHOOK_URL}",

        // 必填：Bearer Token。支持 {env:...} 环境变量和 {file:...} 文件读取。
        // 推荐：{env:OPENCODE_WEBHOOK_TOKEN}
        // 备选：{file:/etc/secrets/opencode-webhook-token}
        "token": "{env:OPENCODE_WEBHOOK_TOKEN}",

        // 可选：每次 HTTP 请求超时时间（毫秒），默认 10000
        "timeoutMs": 5000,

        // 可选：设为 false 可完全禁用此插件
        "enabled": true,

        // 可选：要监听的事件子集，缺省为全部四类
        "events": [
          "session_idle",
          "session_error",
          "permission_asked",
          "question_asked"
        ],

        // 可选：项目显示名称，会进入通知 envelope/card
        "projectDisplayName": "示例项目",

        // 可选：Question/Permission 内容模式，默认 strict（安全）
        // strict：仅类别和计数；summary：清洗截断的摘要；full：显式发送
        // 白名单内的完整问题/权限内容。full 可能泄露业务文本和目标路径，
        // 仅在明确接受该风险时启用。
        // "actionContentMode": "full"
        "actionContentMode": "strict",

        // 可选：运行时元数据诊断：off（默认）、once 或 sample
        // once：每阶段每进程最多一条；sample：每阶段最多 8 条并去重
        // "metadataDiagnostics": "sample"
        "metadataDiagnostics": "off"
      }
    ]
  ]
}
